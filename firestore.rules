rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function isDienNuocAdmin() {
      return signedIn() && currentUid() == "0qLfPFJrkRV8t7HltKExz5eMfbJ2";
    }

    function hasPlayersAfter() {
      return request.resource.data.players is list;
    }

    function hasPlayersBefore() {
      return resource.data.players is list;
    }

    function amPlayerAfter() {
      return hasPlayersAfter()
        && request.resource.data.players.exists(p, p.uid == currentUid());
    }

    function amPlayerBefore() {
      return hasPlayersBefore()
        && resource.data.players.exists(p, p.uid == currentUid());
    }

    // Namespace của dien-nuoc-app.
    // App này dùng collection /rooms/** nên phải giữ rule riêng,
    // nếu không khi deploy rule từ project khác lên cùng Firebase thì app điện nước hoặc Splendor sẽ chặn nhau.
    match /rooms/{document=**} {
      allow read, write: if isDienNuocAdmin();
    }

    // Hồ sơ người chơi Splendor: ai đăng nhập cũng đọc được,
    // nhưng chỉ chủ tài khoản mới được tạo/cập nhật hồ sơ của mình.
    match /splendor_users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && currentUid() == uid;
      allow delete: if false;
    }

    // Phòng chơi Splendor: room_1 đến room_5.
    // - create: cho phép tạo room mặc định
    // - update: cho phép nếu user là player trước khi ghi hoặc là player sau khi ghi
    //   -> hợp lệ cho join, leave, heartbeat, host start game, host chỉnh phòng.
    match /splendor_rooms/{roomId} {
      allow read: if signedIn();

      allow create: if signedIn() && roomId.matches('room_[1-5]');

      allow update: if signedIn()
        && roomId.matches('room_[1-5]')
        && hasPlayersAfter()
        && (amPlayerBefore() || amPlayerAfter());

      allow delete: if false;
    }

    // Đồng bộ thời gian máy chủ cho Splendor.
    match /splendor_time/{docId} {
      allow read, write: if signedIn();
    }

    // Mặc định chặn toàn bộ namespace khác.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

