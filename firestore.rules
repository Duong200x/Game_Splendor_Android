rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // 1. Chặn bên collection "rooms" của dự án khác
    // Chỉ cho phép admin UID được truy cập (dựa trên tài khoản quanly@diennuoc.com)
    match /rooms/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == "0qLfPFJrkRV8t7HltKExz5eMfbJ2";
    }

    // 2. Cấu hình cho Splendor Online
    
    // Hồ sơ người chơi: Mỗi người chỉ được sửa của chính mình
    match /splendor_users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Phòng chơi Splendor: room_1 đến room_5
    match /splendor_rooms/{roomId} {
      allow read: if signedIn();
      
      // Chỉ cho phép tạo các phòng mặc định (room_1..5)
      allow create: if signedIn() && roomId.matches('room_[1-5]');

      // Cho phép cập nhật nếu người chơi có trong danh sách players (dùng để Join, Host chỉnh settings, Heartbeat)
      allow update: if signedIn()
        && (request.resource.data.players is list)
        && request.resource.data.players.exists(p, p.uid == request.auth.uid);
      
      allow delete: if false;
    }

    // Đồng bộ thời gian máy chủ (splendor_time/now)
    match /splendor_time/{docId} {
      allow read, write: if signedIn();
    }
  }
}

